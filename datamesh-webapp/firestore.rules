rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow write: if ( request.auth.uid == request.resource.data.owner ) 
    }
    match /Dataset/{id} {
    	allow read, write: if true
    }
    match /Comparison/{id} {
    	allow read, write: if true
      match /{document=**} {    
        allow read, write: if true
        allow read: if true
      }         
    }   
    match /SqlJupiterDoc/{id} {
    	allow read, write: if true
      match /{document=**} {    
        allow read, write: if true
      }         
    }      
    match /DatasetGroup/{id} {
    	allow read, write: if true
      match /{document=**} {    
        allow read, write: if true
        allow read: if true
      }         
    } 
    match /ComparisonGroup/{id} {
    	allow read, write: if true
      match /{document=**} {    
        allow read, write: if true
        allow read: if true
      }         
    }    
    match /SqlJupiterGroup/{id} {
    	allow read, write: if true
      match /{document=**} {    
        allow read, write: if true
        allow read: if true
      }         
    }       
    match /ConnectionGroup/{id} {
    	allow read, write: if true
      match /{document=**} {    
        allow read, write: if true
        allow read: if true
      }         
    }        
    match /Connection/{id} {
    	allow read, write: if true
      match /{document=**} {    
        allow read, write: if true
        allow read: if true
      }         
    } 
    match /ModelGroup/{id} {
    	allow read, write: if true
      match /{document=**} {    
        allow read, write: if true
        allow read: if true
      }         
    }      
    match /Model/{id} {
    	allow read, write: if true
      match /{document=**} {    
        allow read, write: if true
        allow read: if true
      }         
    }           
    
  }
}